---
layout: layout.njk
title: Get Your Free 5-Point Citadel Audit
---

<div class="container" style="padding-top: 2rem; padding-bottom: 4rem; max-width: 800px; text-align: center;">

  <h2 class="bifurcation-title" style="margin-bottom: 1rem;">The Great Work Begins with a Diagnosis</h2>
  <p class="bifurcation-subtitle" style="margin-bottom: 2.5rem;">Enter your details to receive your complimentary 5-Point Citadel Audit.</p>

  <p style="margin-bottom: 1.5rem; max-width: 600px; margin-left: auto; margin-right: auto;">This is not a generic checklist. This is an alchemical diagnostic designed to find the specific fractures in your business's architecture—from your signal (Ignis) to your systems (Terra).</p>
  
  <p style="margin-bottom: 2.5rem; max-width: 600px; margin-left: auto; margin-right: auto;">Find the "lead" that contaminates your signal, so you can begin the work of transmutation.</p>

  <!-- 
    This form "simulates" the submission by redirecting to your audit page.
    I've added Name (required) and Phone (optional).
  -->
  <form 
    action="/audit-delivery/" 
    method="GET" 
    style="max-width: 500px; margin: 0 auto; text-align: left;"
  >
    
    <!-- Name Field (Required) -->
    <div style="margin-bottom: 1.5rem;">
      <label for="name" style="display: block; margin-bottom: 0.5rem; font-family: 'Lato', sans-serif; font-weight: 600;">Your Name</label>
      <input 
        type="text" 
        id="name" 
        name="name" 
        placeholder="e.g., Will Johnson" 
        required
        style="width: 100%; padding: 0.75rem 1rem; border: 1px solid var(--border-color); background-color: #fff; border-radius: 8px; font-family: 'Lato', sans-serif;"
      >
    </div>

    <!-- Email Field (Required) -->
    <div style="margin-bottom: 1.5rem;">
      <label for="email" style="display: block; margin-bottom: 0.5rem; font-family: 'Lato', sans-serif; font-weight: 600;">Your Email Address</label>
      <input 
        type="email" 
        id="email" 
        name="email" 
        placeholder="you@yourcompany.com" 
        required
        style="width: 100%; padding: 0.75rem 1rem; border: 1px solid var(--border-color); background-color: #fff; border-radius: 8px; font-family: 'Lato', sans-serif;"
      >
    </div>

    <!-- Phone Field (Optional) -->
    <div style="margin-bottom: 2rem;">
      <label for="phone" style="display: block; margin-bottom: 0.5rem; font-family: 'Lato', sans-serif; font-weight: 600;">Phone Number (Optional)</label>
      <input 
        type="tel" 
        id="phone" 
        name="phone" 
        placeholder="(555) 123-4567"
        style="width: 100%; padding: 0.75rem 1rem; border: 1px solid var(--border-color); background-color: #fff; border-radius: 8px; font-family: 'Lato', sans-serif;"
      >
    </div>
    
    <button 
      type="submit" 
      class="form-button" 
      style="width: 100%;"
    >
      Download Your Free Audit
    </button>
  </form>

</div>