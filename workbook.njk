    <style>
        /* * ===============================================
         * 1. ALCHEMICAL THEME & CSS VARIABLES
         * ===============================================
        */

        :root {
            /* Light "Lab Coat" Theme (Default) */
            --bg-primary: #FFFEFA;       /* Light Parchment */
            --bg-secondary: #ffffff;     /* Pure White (for boxes) */
            --bg-input: #ffffff;         /* White text areas */
            --text-primary: #3D1111;     /* Dark Maroon */
            --text-secondary: #5C1A1A;   /* Medium Maroon */
            --text-accent: #B89B3E;      /* Dark Gold (for print/light) */
            --border-primary: #3D1111;   /* Dark Maroon */
            --border-secondary: #c0c0c0; /* Ash */
            --border-accent: #B89B3E;    /* Dark Gold */
            --shadow-color: rgba(0,0,0,0.1);
        }

        [data-theme="dark"] {
            /* Dark "Forge" Theme */
            --bg-primary: #1a0a0a;       /* Darkest Maroon (Forge) */
            --bg-secondary: #0f0606;     /* Near Black (for boxes) */
            --bg-input: #1a0a0a;         /* Darkest Maroon */
            --text-primary: #F0F0F0;     /* Parchment */
            --text-secondary: #C0C0C0;   /* Ash */
            --text-accent: #D4AF37;      /* Bright Gold (for dark) */
            --border-primary: #3D1111;   /* Dark Maroon */
            --border-secondary: #3D1111; /* Dark Maroon */
            --border-accent: #D4AF37;    /* Bright Gold */
            --shadow-color: rgba(0,0,0,0.5);
        }

        /* * ===============================================
         * 2. BASE STYLES (Applies to both themes)
         * ===============================================
        */
        
        body {
            background-color: var(--bg-primary);
            color: var(--text-primary);
            font-family: 'Lato', sans-serif;
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            margin: 0;
            padding: 0;
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        .forge-page {
            max-width: 800px;
            margin: 20px auto;
            padding: 20px 40px;
            background-color: var(--bg-primary);
            border: 1px solid var(--border-secondary);
            box-shadow: 0 10px 30px var(--shadow-color);
            transition: background-color 0.3s ease, border-color 0.3s ease;
        }
        
        .forge-h1 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 3.5rem;
            font-weight: 700;
            color: var(--text-accent);
            text-align: center;
            line-height: 1.1;
            margin-bottom: 1rem;
            transition: color 0.3s ease;
        }
        .forge-h2 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 2.5rem;
            font-weight: 600;
            color: var(--text-primary);
            border-bottom: 1px solid var(--border-accent);
            padding-bottom: 10px;
            margin-top: 2.5rem;
            margin-bottom: 1rem;
            transition: color 0.3s ease, border-color 0.3s ease;
        }
        .forge-h3 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.75rem;
            font-weight: 600;
            color: var(--text-primary);
            opacity: 0.8;
            margin-top: 2rem;
            margin-bottom: 0.5rem;
            transition: color 0.3s ease;
        }
        .forge-motto {
            font-family: 'Cormorant Garamond', serif;
            font-style: italic;
            font-size: 1.2rem;
            color: var(--text-secondary);
            text-align: center;
            margin-top: 1rem;
            margin-bottom: 3rem;
            transition: color 0.3s ease;
        }
        .forge-p {
            font-size: 1.1rem;
            margin-bottom: 1.5rem;
            color: var(--text-primary);
            transition: color 0.3s ease;
        }
        .forge-initiation {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.3rem;
            color: var(--text-secondary);
            border-left: 3px solid var(--border-accent);
            padding-left: 20px;
            margin: 2rem 0;
            font-style: italic;
            transition: color 0.3s ease, border-color 0.3s ease;
        }
        .forge-strong {
            font-weight: 700;
            color: var(--text-primary);
            transition: color 0.3s ease;
        }
        .forge-audit-box {
            background-color: var(--bg-secondary);
            border: 1px solid var(--border-secondary);
            border-left: 4px solid var(--border-accent);
            padding: 25px;
            margin-top: 1.5rem;
            border-radius: 4px;
            transition: background-color 0.3s ease, border-color 0.3s ease;
        }
        .forge-audit-label {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.2rem;
            font-weight: 700;
            color: var(--text-accent);
            display: block;
            margin-bottom: 10px;
            transition: color 0.3s ease;
        }
        .forge-textarea {
            width: 100%;
            height: 150px;
            background-color: var(--bg-input);
            border: 1px dashed var(--border-primary);
            color: var(--text-primary);
            font-family: 'Lato', sans-serif;
            font-size: 1rem;
            padding: 15px;
            box-sizing: border-box; 
            border-radius: 4px;
            transition: background-color 0.3s ease, border-color 0.3s ease, color 0.3s ease;
        }
        .forge-textarea:focus {
            outline: none;
            border-style: solid;
            border-color: var(--border-accent);
        }
        
        .forge-cta {
            background-color: var(--bg-secondary);
            border: 1px solid var(--border-secondary);
            padding: 30px;
            text-align: center;
            margin-top: 3rem;
            border-radius: 4px;
            transition: background-color 0.3s ease, border-color 0.3s ease;
        }
        .forge-cta-button {
            display: inline-block;
            background-color: var(--text-accent);
            color: var(--bg-primary);
            font-family: 'Lato', sans-serif;
            font-size: 1rem;
            font-weight: 700;
            text-transform: uppercase;
            text-decoration: none;
            padding: 15px 30px;
            border-radius: 50px;
            transition: all 0.3s ease;
            border: 2px solid var(--text-accent);
        }
        .forge-cta-button:hover {
            background-color: transparent;
            color: var(--text-accent);
            transform: translateY(-3px);
        }

        /* * ===============================================
         * 3. CONTROL BAR (Theme Toggle & Download)
         * ===============================================
        */
        .control-bar {
            position: fixed;
            top: 20px;
            right: 20px;
            display: flex;
            gap: 10px;
            z-index: 1000;
        }
        .control-button {
            background-color: var(--bg-secondary);
            border: 1px solid var(--border-secondary);
            border-radius: 50px;
            padding: 8px;
            cursor: pointer;
            box-shadow: 0 4px 10px var(--shadow-color);
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .control-button svg {
            width: 24px;
            height: 24px;
            stroke: var(--text-accent);
            fill: none;
            transition: all 0.3s ease;
        }
        #icon-sun { display: none; }
        #icon-moon { display: block; }
        
        [data-theme="dark"] #icon-sun { display: block; }
        [data-theme="dark"] #icon-moon { display: none; }

        /* Style for the Download PDF button */
        #download-pdf {
            text-decoration: none;
            padding: 8px 16px; /* Make it a bit wider */
            font-family: 'Lato', sans-serif;
            font-size: 0.9rem;
            font-weight: 700;
            color: var(--text-accent);
        }
        #download-pdf svg {
            stroke: var(--text-accent);
            width: 20px;
            height: 20px;
            margin-right: 8px;
        }

        /* * ===============================================
         * 4. PRINT STYLES (The "Printable Journal")
         * ===============================================
        */
        @media print {
            body {
                background-color: #ffffff !important; /* Force white for print */
                color: #000000 !important; /* Force black for print */
            }
            .forge-page {
                border: none;
                box-shadow: none;
                margin: 0;
                padding: 0;
            }
            .forge-h1 { color: #3D1111 !important; }
            .forge-h2 { color: #3D1111 !important; }
            .forge-h3 { color: #3D1111 !important; }
            .forge-p { color: #000000 !important; }
            .forge-strong { color: #000000 !important; }
            .forge-initiation { color: #3D1111 !important; border-left-color: #B89B3E !important; }
            .forge-audit-label { color: #B89B3E !important; }
            .forge-textarea {
                height: 200px;
                background: #fdfdfd !important; /* Force light background */
                border: 1px dashed #999 !important;
                color: #000000 !important;
            }
            .control-bar, .forge-cta {
                display: none !important; /* Hide controls & cta on print */
            }
        }
    </style>
</head>
