        // --- Export Function ---
        function exportData() {
            let exportString = "Alchemical Workshop Journal Audits\n=================================\n\n"; // Title updated
            let entriesFound = false;

            for (let i = 0; i < workshopData.length; i++) { // Use workshopData
                const dayData = workshopData[i];
                const dayNum = dayData.day;
                const entry = loadJournalEntry(dayNum);
                if (entry && entry.trim() !== '') {
