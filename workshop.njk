        // --- Gemini API Call Added Back ---
         async function getAiReflection(journalText, dayAuditPrompt) {
             aiReflectBtn.disabled = true;
             aiReflectBtn.innerHTML = '<span class="spinner"></span> Thinking...'; // Add spinner
             aiResponseArea.classList.remove('hidden', 'error');
             aiResponseArea.classList.add('loading');
             aiResponseArea.innerHTML = '<div class="spinner" style="margin: 0 auto;"></div>'; // Show centered spinner in response area

             const apiKey = ""; // Leave blank - Canvas handles this
             const apiUrl = `https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash-latest:generateContent?key=${apiKey}`;
             
              // Updated System Prompt for Alchemical Workshop
              const systemPrompt = `Act as an insightful alchemical guide, deeply familiar with the concepts in the '90-Day Alchemical Workshop' focused on embodiment and transmutation through IGNIS, AQUA, TERRA, and AER. Analyze the following journal entry written in response to the specific Daily Audit prompt for Day ${workshopData[currentDayIndex].day}: "${dayAuditPrompt}". 
              
              Your analysis should:
              1. Acknowledge the user's reflection and identify 1-2 key insights or struggles mentioned.
              2. Connect their entry *directly* to the relevant alchemical stage (IGNIS, AQUA, TERRA, AER) or specific concepts for that day/week (e.g., Inner Forge, Prima Materia, Covenant of Clarity, Porta Doloris, Blueprint Method, Invisible Infrastructure, Alchemical Compass, Quinta Essentia). Use the specific terminology from the workshop.
              3. Offer a brief, encouraging insight or suggest a subtle shift in perspective based on the workshop's principles. Avoid giving generic advice.
              4. Ask 1 clarifying or deepening question to guide their next reflection.
              5. Maintain a wise, encouraging, and slightly mystical/alchemical tone.
              6. Keep the response concise (2-3 short paragraphs). Format using paragraphs. Do not use markdown (bold, italics).`;

              const userQuery = `Journal Entry for Audit Prompt "${dayAuditPrompt}":\n"${journalText}"`;

              const payload = {
                  contents: [{ parts: [{ text: userQuery }] }],
                  systemInstruction: {
                      parts: [{ text: systemPrompt }]
                  },
              };

              let retries = 0;
              const maxRetries = 5;
              let delay = 1000; // Start with 1 second

              while (retries < maxRetries) {
                  try {
                      const response = await fetch(apiUrl, {
                          method: 'POST',
                          headers: { 'Content-Type': 'application/json' },
                          body: JSON.stringify(payload)
                      });

                      if (!response.ok) {
                          if (response.status === 429 || response.status >= 500) {
                              throw new Error(`API Error: ${response.status}`);
                          } else {
                              const errorResult = await response.json();
                              console.error("API Error:", errorResult);
                              aiResponseArea.innerHTML = `Error: ${errorResult.error?.message || 'Failed to get reflection.'}`;
                              aiResponseArea.classList.add('error');
                              aiResponseArea.classList.remove('loading', 'hidden');
                              aiReflectBtn.innerHTML = 'Reflect with AI ✨';
                              aiReflectBtn.disabled = journalTextarea.value.trim().length === 0; 
                              return; 
                          }
                      }

                      const result = await response.json();
                      const candidate = result.candidates?.[0];

                      if (candidate && candidate.content?.parts?.[0]?.text) {
                          const text = candidate.content.parts[0].text;
                          const formattedText = text.split('\n').filter(p => p.trim() !== '').map(p => `<p>${p}</p>`).join(''); // Ensure paragraphs have content
                          aiResponseArea.innerHTML = formattedText;
                          aiResponseArea.classList.remove('loading', 'hidden', 'error');
                          aiReflectBtn.innerHTML = 'Reflect with AI ✨';
                          aiReflectBtn.disabled = journalTextarea.value.trim().length === 0; 
                          return; 
                      } else {
                           throw new Error("Invalid response structure from API.");
                      }
                  } catch (error) {
                      console.warn(`API call failed (attempt ${retries + 1}):`, error);
                      retries++;
                      if (retries >= maxRetries) {
                          aiResponseArea.innerHTML = 'Error: Could not get reflection after multiple attempts. Please try again later.';
                          aiResponseArea.classList.add('error');
                          aiResponseArea.classList.remove('loading', 'hidden');
                          aiReflectBtn.innerHTML = 'Reflect with AI ✨';
                          aiReflectBtn.disabled = journalTextarea.value.trim().length === 0; 
                          break; 
                      }
                       await new Promise(resolve => setTimeout(resolve, delay));
                        delay *= 2; 
                  }
               }
         }
        // --- End Gemini API Call ---


        function renderDay(dayIndex) {
            mainContent.classList.remove('is-visible');
            localStorage.setItem(`${LOCAL_STORAGE_PREFIX}currentDay`, dayIndex);
            
            const data = workshopData[dayIndex]; // Use workshopData
            if (!data) return;

            const dayNum = data.day; 

            // --- Clear previous AI response on day change - Added back ---
             aiResponseArea.classList.add('hidden');
             aiResponseArea.classList.remove('loading', 'error');
             aiResponseArea.innerHTML = '';
             aiReflectBtn.innerHTML = 'Reflect with AI ✨'; // Reset button text
            // --- End clearing ---


            setTimeout(() => {
                 // Update header elements with new data structure
                passTitle.textContent = data.pass; // Use 'pass' field
                weekTitle.textContent = data.week;
                dayNumber.textContent = `Day ${data.day}`;

                const currentDayNumForProgress = data.day; 
                const percent = Math.round((currentDayNumForProgress / 90) * 100);
                progressText.textContent = `Day ${currentDayNumForProgress} of 90`;
                progressPercent.textContent = `${percent}%`;
                progressBar.style.width = `${percent}%`;

                // Update cards with new data structure
                readingAssignment.textContent = data.reading || '';
                readingCard.style.display = data.reading ? 'block' : 'none';

                dailyFocus.textContent = data.focus || ''; // Use 'focus' field
                dailyPracticumDetails.innerHTML = data.practicum ? `<p>${data.practicum}</p>` : ''; // Use 'practicum' field, wrap in <p>
                practicumCard.style.display = data.focus || data.practicum ? 'block' : 'none'; // Show if either exists

                journalAuditPrompt.textContent = data.audit || ''; // Use 'audit' field
                journalCard.style.display = data.audit ? 'block' : 'none'; // Show if audit exists


                 // Load journal entry and set AI button state - Added back
                 const entry = loadJournalEntry(dayNum);
                 journalTextarea.value = entry;
                 aiReflectBtn.disabled = !entry || entry.trim().length === 0; // Disable if no text
                 
                 // Hide AI elements and journal if no audit prompt for the day - Updated
                 if(!data.audit){
                     journalTextarea.style.display = 'none'; // Hide textarea
                     aiReflectBtn.classList.add('hidden');
                     aiResponseArea.classList.add('hidden');
                 } else {
                     journalTextarea.style.display = 'block'; // Show textarea
                     aiReflectBtn.classList.remove('hidden');
                     // Keep aiResponseArea hidden until populated
                 }


                prevDayBtn.disabled = dayIndex === 0;
                nextDayBtn.disabled = dayIndex === 89;
                markCompleteBtn.disabled = dayIndex === 89;

                prevDayBtn.classList.toggle('disabled', dayIndex === 0);
                nextDayBtn.classList.toggle('disabled', dayIndex === 89);
                markCompleteBtn.classList.toggle('disabled', dayIndex === 89);
                
                if (dayIndex === 89) {
                    markCompleteBtn.textContent = 'Workshop Complete'; // Text updated
                } else {
                    markCompleteBtn.innerHTML = 'Mark as Complete &amp; Continue <svg class="w-5 h-5 ml-2 inline-block" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>';
                }

                updateSidebarActiveState(dayNum); 
                mainContent.scrollTop = 0;
                mainContent.classList.add('is-visible');

            }, 300); 
        }
        
        function populateSidebar() {
            let html = '';
            navLinks.forEach(link => {
                if (link.type === 'pass') { // Check for 'pass' type
                    html += `<h3 class="sidebar-pass px-6 py-2 mt-4 text-sm">${link.label}</h3>`; // Use 'sidebar-pass' class
                } else { // Assumes 'week' type
                    html += `<a href="#" class="sidebar-link block py-2 text-sm" data-day="${link.day}">
                                 ${link.label}
                             </a>`;
                }
            });
            sidebarNav.innerHTML = html;
        }

        function updateSidebarActiveState(dayNum) {
            const links = document.querySelectorAll('.sidebar-link');
            let activeLink = null;

            links.forEach(link => {
                link.classList.remove('active');
                const linkDay = parseInt(link.dataset.day, 10);
                // Find the link whose 'day' is the greatest one less than or equal to current day
                if (linkDay <= dayNum) {
                     if (!activeLink || linkDay > parseInt(activeLink.dataset.day, 10)) {
                         activeLink = link;
                     }
                }
            });
            
             // Special case for Day 90 linking to the last week item
             if (dayNum === 90 && links.length > 0) {
                 const lastLink = links[links.length -1];
                 if(parseInt(lastLink.dataset.day, 10) === 90){
                     activeLink = lastLink;
                 }
             }

            if (activeLink) {
                activeLink.classList.add('active');
            }
        }
        
        function jumpToDay(dayNum) {
            const currentData = workshopData[currentDayIndex]; // Use workshopData
            // Save only if there's an audit prompt for the current day
            if (currentData && currentData.audit) { 
                saveJournalEntry(currentData.day, journalTextarea.value);
            }

            currentDayIndex = dayNum - 1; 
            if (currentDayIndex < 0) currentDayIndex = 0;
            if (currentDayIndex > 89) currentDayIndex = 89;
            renderDay(currentDayIndex);
            
            if (window.innerWidth < 1024) {
                closeMenu();
            }
        }
        
        function nextDay() {
            const currentData = workshopData[currentDayIndex]; // Use workshopData
             // Save only if there's an audit prompt for the current day
            if (currentData && currentData.audit) { 
                saveJournalEntry(currentData.day, journalTextarea.value);
            }

            if (currentDayIndex < 89) {
                currentDayIndex++;
                renderDay(currentDayIndex);
            }
        }
        
        function prevDay() {
            const currentData = workshopData[currentDayIndex]; // Use workshopData
             // Save only if there's an audit prompt for the current day
             if (currentData && currentData.audit) { 
                saveJournalEntry(currentData.day, journalTextarea.value);
            }
            if (currentDayIndex > 0) {
                currentDayIndex--;
                renderDay(currentDayIndex);
            }
        }

        function toggleMenu() {
            sidebar.classList.toggle('-translate-x-full');
            menuOpenIcon.classList.toggle('hidden');
            menuCloseIcon.classList.toggle('hidden');
        }
        
        function closeMenu() {
            sidebar.classList.add('-translate-x-full');
            menuOpenIcon.classList.remove('hidden');
            menuCloseIcon.classList.add('hidden');
        }


        // --- EVENT LISTENERS ---
        
        window.addEventListener('load', () => {
            populateSidebar();
            
            const savedDayIndex = localStorage.getItem(`${LOCAL_STORAGE_PREFIX}currentDay`);
            if (savedDayIndex) {
                currentDayIndex = parseInt(savedDayIndex, 10);
                if (currentDayIndex < 0 || currentDayIndex > 89 || isNaN(currentDayIndex)) {
                    currentDayIndex = 0; 
                }
            }
            
            renderDay(currentDayIndex);
            
            // Add Listeners
            prevDayBtn.addEventListener('click', prevDay);
            nextDayBtn.addEventListener('click', nextDay);
            markCompleteBtn.addEventListener('click', nextDay);
            menuToggle.addEventListener('click', toggleMenu);
            exportBtn.addEventListener('click', exportData); 

             // AI Reflect Button Listener - Added back
             aiReflectBtn.addEventListener('click', () => {
                 const currentJournalText = journalTextarea.value;
                 const currentDayData = workshopData[currentDayIndex];
                 const currentDayAuditPrompt = currentDayData.audit; // Use audit prompt
                 if (currentJournalText && currentJournalText.trim().length > 0 && currentDayAuditPrompt) {
                     getAiReflection(currentJournalText, currentDayAuditPrompt);
                 } else {
                     showCustomAlert("Please write something in your journal before reflecting with AI.");
                 }
             });


            // Save journal entry on input
            journalTextarea.addEventListener('input', () => {
                const currentData = workshopData[currentDayIndex]; // Use workshopData
                 // Save only if there's an audit prompt for the current day
                if (currentData && currentData.audit) { 
                   saveJournalEntry(currentData.day, journalTextarea.value);
                }
            });
             
            
            sidebarNav.addEventListener('click', (e) => {
                if (e.target.tagName === 'A' && e.target.dataset.day) {
                    e.preventDefault();
                    jumpToDay(parseInt(e.target.dataset.day, 10));
                }
            });

            setTimeout(() => {
                mainContent.classList.add('is-visible');
            }, 50);
        });
        
    </script>
