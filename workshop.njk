<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Alchemical Workshop</title> 
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600;700&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
    
    <style>
        /*
         * ===============================================
         * 1. CSS Variables & Base Styles (Alchemical Theme)
         * ===============================================
         */
        :root {
            --maroon: #5C1A1A;
            --maroon-dark: #3D1111;
            --maroon-darkest: #1a0a0a;
            --gold: #D4AF37;
            --white: #FFFFFF;
            --text-primary: #F0F0F0;
            --text-secondary: #C0C0C0;
            
            --font-heading: 'Cormorant Garamond', serif;
            --font-body: 'Lato', sans-serif;

            --shadow-light: 0 5px 15px rgba(0, 0, 0, 0.1);
            --shadow-dark: 0 10px 30px rgba(0, 0, 0, 0.3);
        }

        body {
            font-family: var(--font-body);
            background-color: var(--maroon);
            color: var(--text-primary);
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        /* Base Typography */
        h1, h2, h3, h4, h5, h6, .font-heading {
            font-family: var(--font-heading);
            font-weight: 700;
            color: var(--white);
            letter-spacing: 0.5px;
        }
        
        /* Arcane-inspired Animation for Pass Title (previously Cycle) */
        @keyframes pulseGlow {
            0%, 100% {
                text-shadow: 0 0 5px rgba(212, 175, 55, 0.4), 0 0 10px rgba(212, 175, 55, 0.3);
            }
            50% {
                text-shadow: 0 0 10px rgba(212, 175, 55, 0.7), 0 0 20px rgba(212, 175, 55, 0.5);
            }
        }

        #pass-title { /* Renamed from cycle-title */
            color: var(--gold); 
            font-weight: 700; 
            animation: pulseGlow 4s ease-in-out infinite; 
        }


        /*
         * ===============================================
         * 2. Key Animations (Shimmer & Fade)
         * ===============================================
         */
        
        /* Shimmer Effect for Progress Bar */
        @keyframes shimmerRotate {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        .shimmer-progress {
            background-color: var(--gold);
            position: relative;
            overflow: hidden;
            z-index: 1;
        }

        .shimmer-progress::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: conic-gradient(
                from 0deg,
                transparent 0deg,
                transparent 60deg,
                rgba(255, 255, 255, 0.5) 90deg,
                rgba(255, 255, 255, 1) 120deg,
                rgba(255, 255, 255, 0.5) 150deg,
                transparent 180deg,
                transparent 360deg
            );
            animation: shimmerRotate 4s linear infinite;
            z-index: 2;
            mix-blend-mode: overlay;
        }

        /* Fade-in Effect for Main Content */
        .fade-in {
            opacity: 0;
            transform: translateY(20px);
            transition: opacity 0.6s ease-out, transform 0.6s ease-out;
        }

        .fade-in.is-visible {
            opacity: 1;
            transform: translateY(0);
        }
        
        /* Spinner Animation */
        @keyframes spin {
          to { transform: rotate(360deg); }
        }
        .spinner {
          display: inline-block;
          border: 2px solid rgba(255, 255, 255, 0.3);
          border-radius: 50%;
          border-top-color: var(--gold);
          width: 1em; /* Relative to button font size */
          height: 1em; /* Relative to button font size */
          animation: spin 1s ease-in-out infinite;
          margin-right: 0.5rem; /* Space between spinner and text */
        }


        /*
         * ===============================================
         * 3. Component Styles (Alchemical Theme)
         * ===============================================
         */

        /* Main Content & Scrollbar */
        main {
            background-color: var(--maroon);
        }
        
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

        /* Sidebar */
        .sidebar {
            background: var(--maroon-darkest);
            border-right: 1px solid var(--maroon-dark);
        }
        .sidebar-link {
            color: var(--text-secondary);
            transition: all 0.2s ease;
            transform-origin: left;
            padding-left: 1.5rem; /* Original pl-6 */
        }
        .sidebar-link:hover, .sidebar-link.active {
            color: var(--white);
            background: var(--maroon-dark);
        }
        .sidebar-link.active {
            color: var(--gold);
            border-left: 3px solid var(--gold);
            padding-left: 1.375rem; /* 1.5rem - 3px border */
        }
        .sidebar-pass { /* Renamed from sidebar-cycle */
            font-family: var(--font-heading);
            color: var(--gold);
            font-weight: 600; /* semibold */
        }
        /* Export Button Style */
        .export-btn {
            display: block; /* Make it block level */
            width: calc(100% - 3rem); /* Full width minus padding */
            margin: 2rem 1.5rem 1rem 1.5rem; /* Add margin */
            text-align: center;
            padding: 0.75rem 1rem;
            font-family: var(--font-body);
            font-size: 0.9rem;
            font-weight: 700;
            letter-spacing: 1px;
            text-decoration: none;
            text-transform: uppercase;
            color: var(--gold);
            background-color: transparent;
            border: 2px solid var(--gold);
            border-radius: 50px;
            transition: all 0.3s ease;
            cursor: pointer;
        }
        .export-btn:hover {
            background-color: var(--gold);
            color: var(--maroon-dark);
            box-shadow: 0 5px 15px rgba(212, 175, 55, 0.3);
        }


        /* Mobile Menu Toggle */
        #menu-toggle {
            background: var(--maroon-darkest);
            border: 1px solid var(--maroon-dark);
            color: var(--text-primary);
        }

        /* Header & Progress */
        #week-title {
            color: var(--gold);
            font-weight: 600;
        }
        #progress-bar-bg {
            background-color: var(--maroon-dark);
        }

        /* Task Card (mimics .stage-card) */
        .task-card {
            background-color: var(--maroon-dark);
            border: 1px solid var(--maroon-darkest);
            border-top: 4px solid var(--gold);
            border-radius: 0.75rem; /* rounded-xl */
            padding: 1.5rem; /* p-6 */
            box-shadow: var(--shadow-dark);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        .task-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.5);
            border-color: var(--maroon-darkest); /* Keep border consistent */
            border-top-color: var(--gold); /* Keep top border */
        }
        .task-card h4 {
            color: var(--text-secondary); /* Lighter than slate-400 */
        }
        
        /* Journal Textarea */
        .journal-textarea {
            background: var(--maroon-darkest);
            border: 1px solid var(--maroon-dark);
            color: var(--text-primary);
            border-radius: 0.5rem; /* rounded-lg */
            padding: 1rem; /* p-4 */
            min-height: 200px;
            transition: all 0.3s ease;
        }
        .journal-textarea:focus {
            outline: none;
            border-color: var(--gold);
            box-shadow: 0 0 0 2px rgba(212, 175, 55, 0.5); /* Gold shadow */
        }
        
        /* Primary CTA Button (mimics .cta-button) */
        .primary-btn {
            display: inline-block;
            padding: 0.75rem 1.5rem; /* py-3 px-6 */
            font-family: var(--font-body);
            font-size: 0.9rem; /* Slightly smaller to fit */
            font-weight: 700;
            letter-spacing: 1.5px;
            text-decoration: none;
            text-transform: uppercase;
            color: var(--maroon-dark);
            background-color: var(--gold);
            border: 2px solid var(--gold);
            border-radius: 50px;
            transition: all 0.3s ease;
            cursor: pointer;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        }
        .primary-btn:hover {
            background-color: transparent;
            color: var(--gold);
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
        }
        .primary-btn:disabled, .primary-btn.disabled {
             opacity: 0.5;
             cursor: not-allowed;
             transform: none;
             box-shadow: none;
             background-color: var(--gold);
             color: var(--maroon-dark);
        }

        /* Secondary Button (Ghost Style) */
        .secondary-btn {
            padding: 0.5rem 1rem; /* py-2 px-4 */
            font-family: var(--font-body);
            font-weight: 500; /* medium */
            text-decoration: none;
            color: var(--text-secondary);
            background-color: transparent;
            border: 2px solid var(--maroon-dark);
            border-radius: 50px;
            transition: all 0.3s ease;
            cursor: pointer;
        }
        .secondary-btn:hover:not(:disabled) { /* Add :not(:disabled) */
            background-color: var(--maroon-dark);
            color: var(--white);
            border-color: var(--maroon-dark);
        }
        .secondary-btn:disabled, .secondary-btn.disabled {
            opacity: 0.4;
            cursor: not-allowed;
            background-color: transparent;
            color: var(--text-secondary);
            border-color: var(--maroon-dark); /* Ensure border stays */
        }
         
        /* AI Feature Styles - Added back */
        .ai-reflect-btn {
             margin-top: 1rem;
             display: flex; /* Added for spinner alignment */
             align-items: center; /* Added for spinner alignment */
             justify-content: center; /* Added for spinner alignment */
        }
         .ai-reflect-btn[disabled] { /* Style for disabled AI button */
             opacity: 0.6;
             cursor: not-allowed;
             background-color: transparent;
             color: var(--text-secondary);
             border-color: var(--maroon-dark);
        }
        
        #ai-response-area {
            margin-top: 1rem;
            padding: 1rem;
            background-color: var(--maroon-darkest);
            border: 1px solid var(--maroon-dark);
            border-radius: 0.5rem;
            color: var(--text-secondary);
            font-size: 0.9rem;
            line-height: 1.6;
        }
        #ai-response-area.loading {
             display: flex;
             align-items: center;
             justify-content: center;
             color: var(--gold);
             min-height: 100px; /* Give space for spinner */
        }
        #ai-response-area.error {
             color: #fca5a5; /* Tailwind red-400 */
             border-color: #ef4444; /* Tailwind red-500 */
        }
        #ai-response-area p { margin-bottom: 0.5rem; } /* Spacing for AI response paragraphs */


        /* Prose styles for injected HTML */
        .prose-sm {
            font-size: 0.95rem;
            line-height: 1.6;
        }
        .prose-sm ol, .prose-sm ul {
            padding-left: 1.25rem;
            margin-top: 0.75rem;
        }
        .prose-sm li {
            margin-top: 0.25rem;
        }
        .prose-sm strong {
            color: var(--text-primary);
            font-weight: 600;
        }
        .prose-sm p {
            margin-top: 0.75rem;
            margin-bottom: 0.75rem;
        }
        .prose-sm .italic {
            color: var(--text-secondary);
        }

    </style>
</head>
<body class="text-slate-300"> <div class="flex h-screen">
