                     // Use 'audit' field for title
                    exportString += `Day ${dayNum}: ${dayData.audit}\n-----------------\n`; 
                    exportString += `${entry}\n\n`;
                }
            }

            if (!entriesFound) {
                 showCustomAlert("No journal entries found to export.");
                 return;
            }

            const blob = new Blob([exportString], { type: 'text/plain;charset=utf-8' });
            const link = document.createElement('a');
            link.href = URL.createObjectURL(blob);
             // Filename updated
            link.download = 'Alchemical_Workshop_Journal.txt'; 
            link.style.display = 'none';
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            URL.revokeObjectURL(link.href); 
        }
