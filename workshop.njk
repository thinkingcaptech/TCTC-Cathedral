    <script>
        // --- DATABASE ---
        // NEW Alchemical Workshop Data
        const workshopData = [
            // --- PASS 1: AWARENESS ---
            // Week 1: Foundations & IGNIS
            { day: 1, pass: "PASS 1: THE READ FOR AWARENESS", week: "Week 1: The Foundations & IGNIS", reading: "Preface", focus: "Physics vs. Performance", practicum: 'Notice, in one conversation, when you are "performing" (thinking about what to say next, trying to be liked).', audit: "When did I feel least authentic today? Why?" },
            { day: 2, pass: "PASS 1: THE READ FOR AWARENESS", week: "Week 1: The Foundations & IGNIS", reading: "Ch. 1", focus: "Prima Materia (Intention)", practicum: 'Before 3 small tasks (e.g., sending an email, making coffee), set a clear, one-sentence intention. (e.g., "My intention is to provide clarity.")', audit: "Did my intention match my action? When did my intention get hijacked by my ego?" },
            { day: 3, pass: "PASS 1: THE READ FOR AWARENESS", week: "Week 1: The Foundations & IGNIS", reading: "Ch. 2", focus: "The Inner Forge (Presence)", practicum: 'Ritual of Ignition: For 5 minutes this morning, just sit and observe the "weather" of your mind without judgment.', audit: "What did I observe? Was my mind chaotic or clear?" },
            { day: 4, pass: "PASS 1: THE READ FOR AWARENESS", week: "Week 1: The Foundations & IGNIS", reading: "Ch. 2", focus: "The Indifferent Mind", practicum: 'In one low-stakes conversation, practice being 100% focused on the process (understanding them) and 0% on the outcome (getting them to agree).', audit: 'How did detaching from the "Yes" change how I listened?' },
            { day: 5, pass: "PASS 1: THE READ FOR AWARENESS", week: "Week 1: The Foundations & IGNIS", reading: "Ch. 2", focus: "Attentional Alchemy", practicum: 'Give one person 3 full minutes of unpolluted attention. No phone, no planning your reply. Just receive.', audit: "How did the other person's energy change when they felt truly seen?" },
            { day: 6, pass: "PASS 1: THE READ FOR AWARENESS", week: "Week 1: The Foundations & IGNIS", reading: "Ch. 2", focus: "Tending the Forge", practicum: 'Ritual of Recalibration: Practice the "threshold" ritual. Pause for one disciplined breath when you hang up a call or leave a room.', audit: 'How did this "micro-pause" reset my vessel?' },
            { day: 7, pass: "PASS 1: THE READ FOR AWARENESS", week: "Week 1: The Foundations & IGNIS", reading: "Week 1 Review", focus: "IGNIS Audit", practicum: 'Review your journal notes.', audit: 'What is the biggest "contaminant" in my Inner Forge (e.g., neediness, fear, ego)?' },
            // Week 2: AQUA
            { day: 8, pass: "PASS 1: THE READ FOR AWARENESS", week: "Week 2: AQUA (The Solvent)", reading: "Ch. 3", focus: "The Alchemical Solvent", practicum: 'In one conversation, your only goal is to understand. Ask "why," "help me understand," or "tell me more" at least 3 times.', audit: "What did I learn that I would have missed if I was waiting to speak?" },
            { day: 9, pass: "PASS 1: THE READ FOR AWARENESS", week: "Week 2: AQUA (The Solvent)", reading: "Ch. 3", focus: "Curiosity as Moral System", practicum: 'Identify one assumption you hold about a person or situation. Find one piece of data today that challenges it.', audit: "What assumption did I challenge? What was the truth?" },
            { day: 10, pass: "PASS 1: THE READ FOR AWARENESS", week: "Week 2: AQUA (The Solvent)", reading: "Ch. 4", focus: "Covenant of Clarity", practicum: '(Low-stakes): Start one conversation with a simple Covenant. "My only goal for this chat is to get your honest perspective on X. Is that fair?"', audit: 'How did this "Covenant" change the tone of the interaction?' },
            { day: 11, pass: "PASS 1: THE READ FOR AWARENESS", week: "Week 2: AQUA (The Solvent)", reading: "Ch. 4", focus: "Apocalypsis (The Unveiling)", practicum: 'Listen as a diagnostician. In one meeting, just listen for the architecture of the problem, not the symptoms.', audit: "What was the real problem (the fracture) beneath the stated problem?" },
            { day: 12, pass: "PASS 1: THE READ FOR AWARENESS", week: "Week 2: AQUA (The Solvent)", reading: "Ch. 5", focus: "Porta Doloris (The Pain Gate)", practicum: 'Observe (don\'t act) for the "gravity" of a problem someone mentions. Listen for the emotional/personal consequence, not just the intellectual one.', audit: "What was the real gravity of the problem I heard today?" },
            { day: 13, pass: "PASS 1: THE READ FOR AWARENESS", week: "Week 2: AQUA (The Solvent)", reading: "Ch. 3-5", focus: "The Fluid System", practicum: 'Notice when a conversation "breaks script." Instead of panicking, practice "yielding" like water and asking an Aqua question.', audit: 'I felt resistance when... How did "yielding" instead of "pushing" work?' },
            { day: 14, pass: "PASS 1: THE READ FOR AWARENESS", week: "Week 2: AQUA (The Solvent)", reading: "Week 2 Review", focus: "AQUA Audit", practicum: 'Review your journal notes.', audit: 'When am I most impatient? When do I "pitch" instead of "diagnose"?' },
            // Week 3: TERRA
            { day: 15, pass: "PASS 1: THE READ FOR AWARENESS", week: "Week 3: TERRA (The Architecture)", reading: "Ch. 6", focus: "The Mentor's Reframe", practicum: 'In one discussion, consciously frame the other person as the "Hero" and yourself as the "Mentor" (guide).', audit: 'How did this stop me from trying to be the "Hero" who saves the day?' },
            { day: 16, pass: "PASS 1: THE READ FOR AWARENESS", week: "Week 3: TERRA (The Architecture)", reading: "Ch. 6", focus: "Prescription vs. Co-Creation", practicum: 'Notice when you "prescribe" a solution. Stop, and ask an Aqua question instead (e.g., "What do you think the best path forward is?").', audit: "I prescribed a solution when... What happened when I asked instead?" },
            { day: 17, pass: "PASS 1: THE READ FOR AWARENESS", week: "Week 3: TERRA (The Architecture)", reading: "Ch. 7", focus: "The Blueprint Method", practicum: 'In a planning session (even with yourself), identify the: 1) Foundation (The truth), 2) Principles (The values), 3) Design (The action).', audit: "Did this 3-step Blueprint create clarity?" },
            { day: 18, pass: "PASS 1: THE READ FOR AWARENESS", week: "Week 3: TERRA (The Architecture)", reading: "Ch. 7", focus: "Mapping Your Solution", practicum: 'Take one of your "features" (a skill you have) and map it to a Principle it serves. (e.g., "My coding skill" serves the Principle of "Operational Clarity.")', audit: "How does this change how I talk about my value?" },
            { day: 19, pass: "PASS 1: THE READ FOR AWARENESS", week: "Week 3: TERRA (The Architecture)", reading: "Ch. 8", focus: "The Alchemical Exchange", practicum: 'Re-frame one "cost" in your life (e.g., gym membership) as an "exchange" (e.g., "I exchange money for physical energy").', audit: 'How does framing it as a mutual "exchange" change its value?' },
            { day: 20, pass: "PASS 1: THE READ FOR AWARENESS", week: "Week 3: TERRA (The Architecture)", reading: "Ch. 8", focus: "The Key of Free Will", practicum: 'At the end of a discussion, instead of pushing for your outcome, honor their free will. "Does this feel like the right path forward for you?"', audit: "What did it feel like to give them back 100% of the power?" },
