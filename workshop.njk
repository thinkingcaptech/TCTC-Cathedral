        // --- Local Storage Functions ---
        function getJournalEntryKey(dayNum) {
            return `${LOCAL_STORAGE_PREFIX}day_${dayNum}_journal`;
        }

        function saveJournalEntry(dayNum, text) {
            try {
                localStorage.setItem(getJournalEntryKey(dayNum), text);
                 // Enable/disable AI button based on content - Added back
                 aiReflectBtn.disabled = !text || text.trim().length === 0;
            } catch (e) {
                console.error("Error saving to localStorage:", e);
            }
        }

        function loadJournalEntry(dayNum) {
            try {
                const entry = localStorage.getItem(getJournalEntryKey(dayNum)) || '';
                 // Enable/disable AI button based on loaded content - Added back
                 aiReflectBtn.disabled = !entry || entry.trim().length === 0;
                return entry;
            } catch (e) {
                console.error("Error loading from localStorage:", e);
