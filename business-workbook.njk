                Reserve the $499 Blueprint
            </a>
        </div>
    
    </div>
</div>

<script>
    /* * ===============================================
     * ALCHEMICAL THEME SWITCHER SCRIPT
     * ===============================================
    */
    (function() {
        const toggleButton = document.getElementById('theme-toggle');
        const htmlElement = document.documentElement;

        // 1. The "Physics" (Automatic Detection)
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)');

        function applyTheme(theme) {
            htmlElement.setAttribute('data-theme', theme);
            localStorage.setItem('alchemistTheme', theme);
        }

        // 2. The "Agency" (Manual Toggle)
        toggleButton.addEventListener('click', () => {
            const currentTheme = htmlElement.getAttribute('data-theme');
            const newTheme = (currentTheme === 'dark') ? 'light' : 'dark';
            applyTheme(newTheme);
        });

        // 3. The "Ignition" (On Load)
        const savedTheme = localStorage.getItem('alchemistTheme');
        
        if (savedTheme) {
            applyTheme(savedTheme);
        } else if (prefersDark.matches) {
            applyTheme('dark');
        } else {
            applyTheme('light');
        }

        // 4. The "Living System" (Listen for OS Changes)
        prefersDark.addEventListener('change', (e) => {
            if (!localStorage.getItem('alchemistTheme')) {
                applyTheme(e.matches ? 'dark' : 'light');
            }
        });
        
        // 5. Local Storage for Textareas (The "Vessel Memory")
        const textareas = document.querySelectorAll('.forge-textarea');
        textareas.forEach(textarea => {
            const id = textarea.id;
            
            // Load saved work on init
            const savedValue = localStorage.getItem(`forge-audit-${id}`);
            if (savedValue) {
                textarea.value = savedValue;
            }
            
            // Save work on input
            textarea.addEventListener('input', () => {
                localStorage.setItem(`forge-audit-${id}`, textarea.value);
            });
        });
        
    })();
</script>

</body>
</html>
